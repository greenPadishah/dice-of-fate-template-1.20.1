{
	"schemaVersion": 1,
	"id": "dice-of-fate",
	"version": "${version}",
	"name": "Dice of Fate",
	"description": "This Mod is my first attempt at making a Minecraft Mod, the idea is to have a dice which will change your Fate.",
	"authors": [
		"greenPadishah"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/dice-of-fate/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"name.modid.DiceOfFate"
		],
		"client": [
			"name.modid.DiceOfFateClient"
		]
	},
	"mixins": [
		"dice-of-fate.mixins.json",
		{
			"config": "dice-of-fate.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
	}
}